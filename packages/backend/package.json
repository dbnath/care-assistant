{
  "name": "@care-assistant/backend",
  "version": "0.1.0",
  "private": true,
  "description": "FastAPI backend for elderly care assistant",
  "scripts": {
    "dev": ".venv/bin/uvicorn src.care_assistant.main:app --reload --host 0.0.0.0 --port 8000",
    "start": ".venv/bin/uvicorn src.care_assistant.main:app --host 0.0.0.0 --port 8000",
    "test": ".venv/bin/pytest",
    "test:cov": ".venv/bin/pytest --cov=src/care_assistant --cov-report=html",
    "lint": ".venv/bin/ruff check src tests",
    "format": ".venv/bin/black src tests",
    "clean": "rm -rf .pytest_cache .coverage htmlcov __pycache__ src/**/__pycache__"
  },
  "keywords": [
    "fastapi",
    "healthcare",
    "elderly-care"
  ],
  "author": "",
  "license": "UNLICENSED"
}
