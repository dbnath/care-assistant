{
  "name": "care-assistant-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@care-assistant/mobile",
    "mobile:ios": "npm run ios --workspace=@care-assistant/mobile",
    "mobile:android": "npm run android --workspace=@care-assistant/mobile",
    "backend": "npm run dev --workspace=@care-assistant/backend",
    "backend:test": "npm run test --workspace=@care-assistant/backend",
    "dev": "concurrently \"npm run backend\" \"npm run mobile\"",
    "install:all": "npm install && npm run setup:backend",
    "setup:backend": "cd packages/backend && python -m venv .venv && .venv/bin/pip install -r requirements-dev.txt && .venv/bin/pip install -e .",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "overrides": {
    "react-test-renderer": "18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
